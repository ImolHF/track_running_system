# 会话密钥 — 随机字符串
SECRET_KEY=change-me-to-a-random-string

# Fernet 加密密钥 — 运行 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成
FERNET_KEY=change-me-to-a-fernet-key

# 数据库路径
DATABASE_URL=sqlite:///data/pclock.db

# 自动同步间隔（小时）
SYNC_INTERVAL_HOURS=4

# 首次同步获取天数
INITIAL_SYNC_DAYS=90
